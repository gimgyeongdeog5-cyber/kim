
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>추억의 똥침 타이밍 게임!</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Jua&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Jua', sans-serif; user-select: none; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; background-color: #fef3c7; }
        #game-container { width: 100%; max-width: 400px; height: 600px; background: white; border: 4px solid #d97706; border-radius: 24px; overflow: hidden; position: relative; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.2); }
        .screen { position: absolute; inset: 0; z-index: 10; background: white; }
    </style>
</head>
<body>

    <div id="game-container">
        <!-- 홈 화면 -->
        <div id="screen-home" class="screen flex flex-col items-center justify-center p-6 text-center bg-amber-100">
            <h1 class="text-4xl text-amber-600 mb-4">똥침의 고수!</h1>
            <p class="text-red-500 text-sm font-bold bg-white px-3 py-1 rounded-full mb-8">주의: 퍼펙트 3회 연속 시 게임오버!</p>
            <div class="w-32 h-32 bg-yellow-200 rounded-full mb-8 animate-bounce flex items-center justify-center text-6xl">🍑</div>
            <button id="btn-start" class="w-full py-4 bg-red-500 text-white text-2xl font-bold rounded-xl shadow-lg border-b-4 border-red-800 active:translate-y-1">게임 시작!</button>
        </div>

        <!-- 게임 화면 -->
        <div id="screen-game" class="screen flex flex-col hidden bg-sky-100">
            <div class="p-4 bg-white border-b border-sky-200 text-center text-xl font-bold">SCORE: <span id="game-score" class="text-sky-600">0</span></div>
            <div id="play-area" class="relative flex-grow cursor-pointer overflow-hidden">
                <div id="target-butt" class="absolute w-20 h-20 bg-orange-200 rounded-full border-2 border-orange-600 flex items-center justify-center text-2xl" style="left: -100px; top: 250px;">🍑</div>
                <div id="effect-layer" class="absolute inset-0 pointer-events-none z-20 flex items-center justify-center"></div>
            </div>
            <div class="p-4 bg-white border-t border-sky-200">
                <button id="btn-attack" class="w-full py-5 bg-sky-500 text-white text-xl font-bold rounded-xl shadow-lg active:bg-sky-600">똥침 발사!</button>
            </div>
        </div>

        <!-- 게임 오버 -->
        <div id="screen-over" class="screen flex flex-col items-center justify-center p-6 bg-amber-900 text-white hidden">
            <h2 id="over-title" class="text-3xl font-bold mb-4">게임 종료!</h2>
            <div id="over-score" class="text-5xl font-black mb-8">0</div>
            <button id="btn-restart" class="w-full py-4 bg-yellow-500 text-amber-950 font-bold rounded-xl">다시 도전</button>
        </div>
    </div>

    <script>
        const gameState = { isPlaying: false, score: 0, goodCount: 0, perfectCount: 0 };
        const activeTarget = { x: -100, speed: 5, isActive: false };
        
        function startGame() {
            gameState.isPlaying = true; gameState.score = 0;
            gameState.goodCount = 0; gameState.perfectCount = 0;
            document.getElementById('screen-home').classList.add('hidden');
            document.getElementById('screen-over').classList.add('hidden');
            document.getElementById('screen-game').classList.remove('hidden');
            spawnTarget();
            requestAnimationFrame(gameLoop);
        }

        function spawnTarget() {
            activeTarget.x = -100;
            activeTarget.speed = 5 + Math.random() * 3;
            activeTarget.isActive = true;
        }

        function gameLoop() {
            if (!gameState.isPlaying) return;
            activeTarget.x += activeTarget.speed;
            const target = document.getElementById('target-butt');
            target.style.left = activeTarget.x + 'px';
            if (activeTarget.x > 400) { spawnTarget(); gameState.goodCount = 0; gameState.perfectCount = 0; }
            requestAnimationFrame(gameLoop);
        }

        function performTtongchim() {
            if (!gameState.isPlaying) return;
            const diff = Math.abs(activeTarget.x - 160); // 중앙 좌표 160 근처
            if (diff < 40) {
                gameState.perfectCount++; gameState.goodCount = 0;
                if (gameState.perfectCount >= 3) return endGame("퍼펙트 3회 연속! 게임오버!");
                gameState.score += 200; showEffect("PERFECT!", "#f59e0b");
            } else if (diff < 80) {
                gameState.goodCount++; gameState.perfectCount = 0;
                gameState.score += (gameState.goodCount >= 2 ? 200 : 100);
                showEffect(gameState.goodCount >= 2 ? "GOOD x2!" : "GOOD", "#10b981");
            } else {
                gameState.goodCount = 0; gameState.perfectCount = 0; showEffect("MISS", "#ef4444");
            }
            document.getElementById('game-score').textContent = gameState.score;
            spawnTarget();
        }

        function showEffect(text, color) {
            const el = document.createElement('div');
            el.className = "text-4xl font-black";
            el.style.color = color; el.textContent = text;
            const layer = document.getElementById('effect-layer');
            layer.innerHTML = ''; layer.appendChild(el);
            setTimeout(() => layer.innerHTML = '', 500);
        }

        function endGame(msg) {
            gameState.isPlaying = false;
            document.getElementById('over-title').textContent = msg;
            document.getElementById('over-score').textContent = gameState.score;
            document.getElementById('screen-game').classList.add('hidden');
            document.getElementById('screen-over').classList.remove('hidden');
        }

        document.getElementById('btn-start').addEventListener('click', startGame);
        document.getElementById('btn-restart').addEventListener('click', startGame);
        document.getElementById('btn-attack').addEventListener('click', performTtongchim);
    </script>
</body>
</html>
